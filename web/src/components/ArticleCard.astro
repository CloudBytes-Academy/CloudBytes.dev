---
import TagList from "./TagList.astro";

interface Props {
    href: string;
    title: string;
    description?: string;
    tags?: string[];
}

const { href, title, description, tags = [] } = Astro.props;
---

<article class="box group relative overflow-hidden">
    <a
        href={href}
        aria-label={title}
        class="absolute inset-0 z-10 rounded-box focus-visible:outline focus-visible:outline-primary"
    ></a>

    <div class:list={["box-content", tags.length > 0 && "pb-16"]}>
        <h2 class="text-xl font-semibold text-base-content transition-colors group-hover:text-primary md:text-2xl">
            {title}
        </h2>
        {description && <p class="subtext mt-2">{description}</p>}
    </div>

    {tags.length > 0 ? (
        <div class="absolute inset-x-5 bottom-5 z-20">
            <TagList tags={tags} />
        </div>
    ) : null}
</article>

