---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";
import type { ImageMetadata } from "astro";
import { SITE_TITLE, SITE_URL, TWITTER_SITE } from "../consts";
import { pathToSlug } from "../lib/og/manifest";

const DEFAULT_KEYWORDS = [
    "cloudbytes",
    "cloudbytes.dev",
    "code snippets",
    "tutorials",
    "programming",
    "aws",
    "python",
    "javascript",
];

const ADSENSE_CLIENT = "ca-pub-0503340532690886";

interface Props {
    title: string;
    description: string;
    image?: ImageMetadata | string;
    imageWidth?: number;
    imageHeight?: number;
    imageAlt?: string;
    type?: "website" | "article";
    author?: string;
    twitterCreator?: string;
    keywords?: string[];
    publishedTime?: Date;
    modifiedTime?: Date;
    articleAuthor?: string | string[];
    articleSection?: string;
    articleTags?: string[];
    noindex?: boolean;
    /**
     * Pre-built JSON-LD payloads (already including @context). One <script>
     * tag is emitted per entry. Pages should pass a single graph object
     * built via lib/seo.ts:buildGraph().
     */
    jsonLd?: unknown[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const {
    title,
    description,
    image,
    imageWidth,
    imageHeight,
    imageAlt,
    type = "website",
    author,
    twitterCreator,
    keywords,
    publishedTime,
    modifiedTime,
    articleAuthor,
    articleSection,
    articleTags,
    noindex = false,
    jsonLd,
} = Astro.props;

// Resolve OG image URL + dimensions.
//
// Priority:
//   1. Explicit `image` prop (post heroImage, etc.) — wins.
//   2. Per-page dynamic OG card at `/og/<slug>.png`, where slug is derived
//      from the canonical path. Covered by lib/og/manifest.ts.
//   3. Static `/og-default.png` fallback (generated by scripts/generate-default-og.mjs
//      at prebuild) — only reached if the manifest doesn't have this slug.
const DYNAMIC_OG_SIZE = { width: 1200, height: 630 };

let ogImageUrl: string;
let ogWidth: number | undefined;
let ogHeight: number | undefined;

if (typeof image === "string") {
    ogImageUrl = new URL(image, Astro.site).toString();
    ogWidth = imageWidth;
    ogHeight = imageHeight;
} else if (image) {
    ogImageUrl = new URL(image.src, Astro.site).toString();
    ogWidth = imageWidth ?? image.width;
    ogHeight = imageHeight ?? image.height;
} else {
    const slug = pathToSlug(Astro.url.pathname);
    ogImageUrl = `${SITE_URL}/og/${slug}.png`;
    ogWidth = DYNAMIC_OG_SIZE.width;
    ogHeight = DYNAMIC_OG_SIZE.height;
}

const resolvedImageAlt = imageAlt ?? title;
const metaKeywords = (keywords?.length ? keywords : DEFAULT_KEYWORDS).join(", ");
const robots = noindex ? "noindex,nofollow" : "index,follow";

const articleAuthors = articleAuthor
    ? Array.isArray(articleAuthor)
        ? articleAuthor
        : [articleAuthor]
    : [];
const articleTagList = articleTags ?? [];

const gtagId = String(import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID ?? "").trim();
const enableAnalytics = import.meta.env.PROD && Boolean(gtagId);
const enableAdsense = import.meta.env.PROD;

const gtagInit = enableAnalytics
    ? `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', ${JSON.stringify(gtagId)});`
    : "";

// JSON-LD: pages may pass their own pre-built graph(s). We emit one <script>
// tag per entry so each can be a separate graph if desired.
const ldEntries: unknown[] = jsonLd && jsonLd.length ? jsonLd : [];
const ldStrings = ldEntries.map((e) => JSON.stringify(e));
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/img/icons/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/img/icons/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/img/icons/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/img/icons/favicon-16x16.png" />
<link rel="mask-icon" href="/img/icons/safari-pinned-tab.svg" color="#5bbad5" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="msapplication-TileColor" content="#fdf6e3" />
<meta name="msapplication-config" content="/browserconfig.xml" />
<meta name="theme-color" content="#ffffff" />
<link rel="sitemap" href="/sitemap-index.xml" />

{enableAdsense && <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />}
{enableAnalytics && <link rel="dns-prefetch" href="https://www.googletagmanager.com" />}

<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={`${SITE_URL}/rss.xml`} />
<link rel="alternate" type="application/json" title={`${SITE_TITLE} (JSON Feed)`} href={`${SITE_URL}/feed.json`} />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="robots" content={robots} />
{author && <meta name="author" content={author} />}
<meta name="keywords" content={metaKeywords} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
{ogWidth && <meta property="og:image:width" content={String(ogWidth)} />}
{ogHeight && <meta property="og:image:height" content={String(ogHeight)} />}
<meta property="og:image:alt" content={resolvedImageAlt} />

{type === "article" && publishedTime && (
    <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === "article" && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{type === "article" &&
    articleAuthors.map((name) => <meta property="article:author" content={name} />)}
{type === "article" && articleSection && (
    <meta property="article:section" content={articleSection} />
)}
{type === "article" &&
    articleTagList.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={TWITTER_SITE} />
{twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
<meta property="twitter:image:alt" content={resolvedImageAlt} />

{enableAdsense && (
    <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
        crossorigin="anonymous"></script>
)}

{enableAnalytics && (
    <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
        <script is:inline set:html={gtagInit} />
    </>
)}

{ldStrings.map((s) => (
    <script type="application/ld+json" set:html={s} />
))}
