---
import type { ImageMetadata } from "astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Layout from "./Layout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";
import TagList from "../components/TagList.astro";
import { SECTION_LABELS, SITE_TITLE, SITE_URL, TWITTER_SITE } from "../consts";
import { buildBreadcrumbs } from "../utils/breadcrumbs";
import {
    adaptBreadcrumbs,
    buildArticle,
    buildBreadcrumbList,
    buildFaqPage,
    buildGraph,
    buildHowTo,
} from "../lib/seo";
import { resolvePostAuthor } from "../lib/authors";
import { pathToSlug } from "../lib/og/manifest";

type NavLink = { title: string; href: string };
type HowToData = {
    totalTime?: string;
    estimatedCost?: { currency: string; value: string };
    tools?: string[];
    supplies?: string[];
    steps: { title: string; description: string }[];
};
type FaqData = { question: string; answer: string }[];

interface Props {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    category: string;
    categorySlug: string;
    author?: string;
    authorSlug?: string;
    tags?: string[];
    keywords?: string[];
    youtubeId?: string;
    series?: string;
    seriesPrev?: NavLink;
    seriesNext?: NavLink;
    seriesPosition?: number;
    seriesTotal?: number;
    relatedPosts?: NavLink[];
    headings?: Array<{ depth: number; slug: string; text: string }>;
    heroImage?: ImageMetadata;
    heroImageAlt?: string;
    howto?: HowToData;
    faq?: FaqData;
}

const {
    title,
    description,
    pubDate,
    updatedDate,
    category,
    categorySlug,
    author,
    authorSlug,
    tags = [],
    keywords,
    youtubeId,
    series,
    seriesPrev,
    seriesNext,
    seriesPosition,
    seriesTotal,
    relatedPosts = [],
    headings = [],
    heroImage,
    heroImageAlt,
    howto,
    faq,
} = Astro.props;

const breadcrumbs = buildBreadcrumbs(Astro.url.pathname);
if (breadcrumbs.length) breadcrumbs[breadcrumbs.length - 1] = { label: title };

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedAuthor = await resolvePostAuthor({ authorName: author, authorSlug });
const articleSection = SECTION_LABELS[categorySlug] ?? category;

// JSON-LD: BreadcrumbList + Article (+ optional HowTo / FAQ).
// Use the heroImage when provided; otherwise the per-post dynamic OG card
// (which matches the og:image meta) so social and schema stay in sync.
const articleImage = heroImage?.src ?? `${SITE_URL}/og/${pathToSlug(Astro.url.pathname)}.png`;
const articleNodes: unknown[] = [
    buildBreadcrumbList(canonicalUrl, adaptBreadcrumbs(breadcrumbs, Astro.site!)),
    buildArticle({
        url: canonicalUrl,
        headline: title,
        description,
        datePublished: pubDate,
        dateModified: updatedDate ?? pubDate,
        image: articleImage,
        author: resolvedAuthor,
        keywords,
        articleSection,
        speakable: true,
    }),
];

if (howto) {
    articleNodes.push(
        buildHowTo({
            url: canonicalUrl,
            name: title,
            description,
            image: articleImage,
            totalTime: howto.totalTime,
            estimatedCost: howto.estimatedCost,
            tools: howto.tools,
            supplies: howto.supplies,
            steps: howto.steps,
        }),
    );
}

if (faq && faq.length) {
    articleNodes.push(buildFaqPage(canonicalUrl, faq));
}

const jsonLd = [buildGraph(articleNodes)];

const layoutImage = heroImage ?? undefined;
const layoutImageAlt = heroImageAlt ?? title;
---

<Layout
    title={`${title} · ${SITE_TITLE}`}
    description={description}
    image={layoutImage}
    imageAlt={layoutImageAlt}
    type="article"
    author={resolvedAuthor.name}
    twitterCreator={TWITTER_SITE}
    keywords={keywords}
    publishedTime={pubDate}
    modifiedTime={updatedDate ?? pubDate}
    articleAuthor={resolvedAuthor.name}
    articleSection={articleSection}
    articleTags={tags}
    jsonLd={jsonLd}
>
    <article class="content-article">
        {breadcrumbs.length ? <Breadcrumbs items={breadcrumbs} class="mb-4" /> : null}
        <h1 class="article-title" data-speakable>{title}</h1>

        <div class="article-byline">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
                <span class="inline-flex items-center gap-2">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-4 w-4 text-base-content/50"
                        aria-hidden="true"
                    >
                        <path d="M20 21a8 8 0 1 0-16 0" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    <span class="text-base-content/70">
                        by{" "}
                        {author && authorSlug ? (
                            <a class="link link-primary" href={`/authors/${authorSlug}/`}>
                                {author}
                            </a>
                        ) : (
                            <span>CloudBytes</span>
                        )}
                    </span>
                </span>

                <span class="inline-flex items-center gap-2 text-base-content/70">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-4 w-4 text-base-content/50"
                        aria-hidden="true"
                    >
                        <path d="M8 2v4" />
                        <path d="M16 2v4" />
                        <path d="M3 10h18" />
                        <path d="M21 6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2Z" />
                    </svg>
                    <FormattedDate date={pubDate} />
                </span>
                {updatedDate && updatedDate.getTime() !== pubDate.getTime() && (
                    <span class="inline-flex items-center gap-1 text-base-content/60 text-xs">
                        Updated
                        <FormattedDate date={updatedDate} />
                    </span>
                )}
            </div>

            <div class="flex items-center gap-2">
                <span class="text-xs font-semibold uppercase tracking-wide text-base-content/60">Category</span>
                <a
                    href={`/${categorySlug}/`}
                    class:list={["tag tag-sm no-underline", `tag-${category.trim().toLowerCase()}`]}
                >
                    {category}
                </a>
            </div>
        </div>

        <p class="sr-only" data-speakable>{description}</p>

        {headings.length ? (
            <div class="mb-6 lg:hidden">
                <details class="box">
                    <summary class="box-content cursor-pointer select-none text-sm font-semibold text-base-content">
                        On this page
                    </summary>
                    <div class="px-5 pb-5">
                        <TableOfContents headings={headings} />
                    </div>
                </details>
            </div>
        ) : null}

        {youtubeId && (
            <div class="mb-8">
                <div class="aspect-video overflow-hidden rounded-box border border-base-300 bg-base-200">
                    <iframe
                        class="h-full w-full"
                        src={`https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&mute=1&playsinline=1&rel=0`}
                        title={title}
                        loading="eager"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                    />
                </div>
            </div>
        )}

        <div class="cb-prose">
            <slot />
        </div>

        {faq && faq.length ? (
            <section class="mt-10">
                <h2 class="text-lg font-semibold text-base-content">Frequently asked questions</h2>
                <dl class="mt-4 grid grid-cols-1 gap-4">
                    {faq.map((q) => (
                        <div class="box">
                            <div class="box-content">
                                <dt class="font-semibold text-base-content">{q.question}</dt>
                                <dd class="mt-2 text-sm text-base-content/80">{q.answer}</dd>
                            </div>
                        </div>
                    ))}
                </dl>
            </section>
        ) : null}

        <div class="mt-8 border-t border-base-300 pt-6">
            <h3 class="text-lg font-semibold text-base-content">Need help?</h3>
            <p class="mt-2 text-sm text-base-content/70">
                Start a discussion on GitHub if you’ve got questions or improvements.
                <a class="link link-primary ml-1" href="https://github.com/CloudBytesDotDev/CloudBytes.dev/discussions" target="_blank" rel="noopener">
                    Open discussions →
                </a>
            </p>
        </div>

        {series && (seriesPrev || seriesNext) ? (
            <div class="mt-10">
                <div class="box">
                    <div class="box-content">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60">Series</p>
                                <h3 class="text-lg font-semibold text-base-content">{series}</h3>
                            </div>

                            {typeof seriesPosition === "number" && typeof seriesTotal === "number" ? (
                                <div class="badge badge-outline border-base-300 text-base-content/70">
                                    Part {seriesPosition} / {seriesTotal}
                                </div>
                            ) : null}
                        </div>

                        <div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2">
                            {seriesPrev ? (
                                <a
                                    href={seriesPrev.href}
                                    class="group flex h-full flex-col justify-between rounded-box border border-base-300 bg-base-100 p-4 no-underline transition hover:border-primary/60 hover:bg-base-200"
                                    aria-label={`Previous in series: ${seriesPrev.title}`}
                                >
                                    <div class="flex items-center justify-between gap-3">
                                        <span class="text-xs font-semibold uppercase tracking-wide text-base-content/60">
                                            Previous
                                        </span>
                                        <span class="text-sm text-base-content/50">←</span>
                                    </div>
                                    <span class="mt-2 line-clamp-2 text-sm font-semibold text-base-content group-hover:text-primary">
                                        {seriesPrev.title}
                                    </span>
                                </a>
                            ) : (
                                <div class="flex h-full flex-col justify-between rounded-box border border-base-300 bg-base-100/40 p-4 opacity-70">
                                    <div class="flex items-center justify-between gap-3">
                                        <span class="text-xs font-semibold uppercase tracking-wide text-base-content/60">
                                            Previous
                                        </span>
                                        <span class="text-sm text-base-content/50">←</span>
                                    </div>
                                    <span class="mt-2 text-sm text-base-content/60">Start of series</span>
                                </div>
                            )}

                            {seriesNext ? (
                                <a
                                    href={seriesNext.href}
                                    class="group flex h-full flex-col justify-between rounded-box border border-base-300 bg-base-100 p-4 no-underline transition hover:border-primary/60 hover:bg-base-200"
                                    aria-label={`Next in series: ${seriesNext.title}`}
                                >
                                    <div class="flex items-center justify-between gap-3">
                                        <span class="text-xs font-semibold uppercase tracking-wide text-base-content/60">
                                            Next
                                        </span>
                                        <span class="text-sm text-base-content/50">→</span>
                                    </div>
                                    <span class="mt-2 line-clamp-2 text-sm font-semibold text-base-content group-hover:text-primary">
                                        {seriesNext.title}
                                    </span>
                                </a>
                            ) : (
                                <div class="flex h-full flex-col justify-between rounded-box border border-base-300 bg-base-100/40 p-4 opacity-70">
                                    <div class="flex items-center justify-between gap-3">
                                        <span class="text-xs font-semibold uppercase tracking-wide text-base-content/60">
                                            Next
                                        </span>
                                        <span class="text-sm text-base-content/50">→</span>
                                    </div>
                                    <span class="mt-2 text-sm text-base-content/60">End of series</span>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        ) : null}

        {tags.length ? <TagList tags={tags} class="mt-8" /> : null}

        {relatedPosts.length ? (
            <div class="mt-10">
                <h3 class="text-lg font-semibold text-base-content">Related posts</h3>
                <div class="mt-4 grid grid-cols-1 gap-3">
                    {relatedPosts.map((p) => (
                        <a href={p.href} class="no-underline">
                            <div class="box">
                                <div class="box-content">
                                    <p class="text-sm font-semibold text-base-content">{p.title}</p>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        ) : null}
    </article>

    <div slot="sidebar">
        <div class="space-y-4">
            {headings.length ? (
                <div class="box">
                    <div class="box-content">
                        <p class="text-sm font-semibold text-base-content">On this page</p>
                        <TableOfContents headings={headings} class="mt-3" />
                    </div>
                </div>
            ) : null}

            <slot name="sidebar" />
        </div>
    </div>
</Layout>
