---
import Page from "../../layouts/Page.astro";
import { SITE_TITLE } from "../../consts";
import { buildGraph, buildItemList, buildWebPage } from "../../lib/seo";
import { getAllPosts, getUniqueAuthors } from "../../utils/posts";

const posts = await getAllPosts();
const authors = getUniqueAuthors(posts);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const description = `Authors with published posts on ${SITE_TITLE}.`;

const jsonLd = [
    buildGraph([
        buildWebPage({
            type: "CollectionPage",
            url: canonicalUrl,
            name: `Authors · ${SITE_TITLE}`,
            description,
        }),
        buildItemList({
            url: canonicalUrl,
            items: authors.map((a) => ({ url: `/authors/${a.slug}/`, name: a.name })),
        }),
    ]),
];
---

<Page
    title={`Authors · ${SITE_TITLE}`}
    description={description}
    heading="Authors"
    subheading="All authors with published posts."
    label="Authors"
    jsonLd={jsonLd}
>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {authors.map((author) => (
            <a
                href={`/authors/${author.slug}/`}
                class="box block no-underline transition hover:border-primary/60 hover:bg-base-200"
                aria-label={`View posts by ${author.name}`}
            >
                <div class="box-content flex items-center justify-between gap-4">
                    <div>
                        <p class="text-lg font-semibold text-base-content">{author.name}</p>
                        <p class="subtext mt-1">{author.count} post{author.count === 1 ? "" : "s"}</p>
                    </div>
                    <span class="text-base-content/40" aria-hidden="true">→</span>
                </div>
            </a>
        ))}
    </div>
</Page>
