---
import ArticleCard from "../../../components/ArticleCard.astro";
import Pagination from "../../../components/Pagination.astro";
import Page from "../../../layouts/Page.astro";
import { SITE_TITLE } from "../../../consts";
import { buildGraph, buildItemList, buildWebPage } from "../../../lib/seo";
import { slugify } from "../../../utils/slugify";
import { getAllPosts, getPostHref, getUniqueTags, paginate } from "../../../utils/posts";

export async function getStaticPaths() {
    const posts = await getAllPosts();
    const tags = getUniqueTags(posts);
    return tags.map((tag) => ({ params: { tag: tag.slug }, props: { tag } }));
}

const { tag } = Astro.props;

const matching = (await getAllPosts()).filter((post) => (post.data.tags ?? []).some((t) => slugify(t) === tag.slug));
const { items, totalPages } = paginate(matching, 1);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const description = `All ${matching.length} posts tagged ${tag.name} on ${SITE_TITLE}.`;

const jsonLd = [
    buildGraph([
        buildWebPage({
            type: "CollectionPage",
            url: canonicalUrl,
            name: `#${tag.name} · ${SITE_TITLE}`,
            description,
        }),
        buildItemList({
            url: canonicalUrl,
            items: items.map((p) => ({ url: getPostHref(p), name: p.data.title })),
        }),
    ]),
];
---

<Page
    title={`#${tag.name} · ${SITE_TITLE}`}
    description={description}
    heading={`#${tag.name}`}
    subheading={`All ${matching.length} posts tagged “${tag.name}”.`}
    label="Tag"
    jsonLd={jsonLd}
>
    {items.map((post) => (
        <ArticleCard
            href={getPostHref(post)}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
        />
    ))}

    <div slot="pagination">
        <Pagination basePath={`/tags/${tag.slug}`} currentPage={1} totalPages={totalPages} />
    </div>
</Page>
