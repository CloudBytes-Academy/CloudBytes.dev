---
import ArticleCard from "../../components/ArticleCard.astro";
import Pagination from "../../components/Pagination.astro";
import Page from "../../layouts/Page.astro";
import { SITE_TITLE } from "../../consts";
import { buildGraph, buildItemList, buildWebPage } from "../../lib/seo";
import { getAllPosts, getPostHref, getUniqueCategories, paginate } from "../../utils/posts";

export async function getStaticPaths() {
    const posts = await getAllPosts();
    const categories = getUniqueCategories(posts);
    return categories.map((category) => ({ params: { category: category.slug }, props: { category } }));
}

const { category } = Astro.props;

const allInCategory = (await getAllPosts()).filter((post) => post.data.categorySlug === category.slug);
const { items, totalPages } = paginate(allInCategory, 1);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site!).toString();
const description = `All ${allInCategory.length} posts in ${category.name} on ${SITE_TITLE} — hands-on tutorials and code snippets.`;

const jsonLd = [
    buildGraph([
        buildWebPage({
            type: "CollectionPage",
            url: canonicalUrl,
            name: `${category.name} · ${SITE_TITLE}`,
            description,
        }),
        buildItemList({
            url: canonicalUrl,
            items: items.map((post) => ({ url: getPostHref(post), name: post.data.title })),
        }),
    ]),
];
---

<Page
    title={`${category.name} · ${SITE_TITLE}`}
    description={description}
    heading={category.name}
    subheading={`All ${allInCategory.length} posts in ${category.name}.`}
    label="Category"
    jsonLd={jsonLd}
>
    {items.map((post) => (
        <ArticleCard
            href={getPostHref(post)}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
        />
    ))}

    <div slot="pagination">
        <Pagination basePath={`/${category.slug}`} currentPage={1} totalPages={totalPages} />
    </div>
</Page>
